{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=lifebits.db"
  },
  "Jwt": {
    "Issuer": "Lifebits",
    "Audience": "LifebitsUsers",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 30,
    "RefreshCookieSameSite": "Lax"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "AzureMaps": {
    "Endpoint": "https://atlas.microsoft.com",
    "SubscriptionKey": ""
  },
  "Nominatim": {
    "Endpoint": "https://nominatim.openstreetmap.org",
    "UserAgent": "LifebitsMvp/1.0 (local-development)",
    "Email": ""
  },
  "GoogleAuth": {
    "ClientId": ""
  },
  "Frontend": {
    "BaseUrl": "http://localhost:5173"
  },
  "Email": {
    "Provider": "Development"
  },
  "PhotoStorage": {
    "Provider": "Local",
    "LocalPath": "App_Data/photos"
  }
}
